# Example environment variables for CP-WBFT

# ── Option A: OpenAI ────────────────────────────────────────────────────────
API_KEY="your_openai_api_key_here"
API_BASE_URL="https://api.openai.com/v1"

# ── Option B: OpenRouter (access 400+ models via one API key) ───────────────
# Get your key at https://openrouter.ai/keys
# OPENROUTER_API_KEY="your_openrouter_api_key_here"
# API_BASE_URL="https://openrouter.ai/api/v1"
#
# Optional — used by OpenRouter for usage tracking / leaderboard attribution:
# OPENROUTER_SITE_URL="https://your-site.com"
# OPENROUTER_SITE_NAME="CP-WBFT"

# ── Optional HTTP(S) proxies ────────────────────────────────────────────────
HTTP_PROXY="http://127.0.0.1:7890"
HTTPS_PROXY="http://127.0.0.1:7890"
